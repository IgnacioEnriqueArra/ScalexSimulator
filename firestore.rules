rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: rooms
    // Document ID: 4-digit string (e.g., '1234')
    // Fields:
    //   - hostId: string (required) - UID of the creator
    //   - isAccelerating: boolean (required) - Gas pedal state
    //   - controllerConnected: boolean (required) - Connection state
    //   - createdAt: timestamp (required) - Creation time
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.hostId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidRoom(data) {
      return hasOnlyAllowedFields(['hostId', 'isAccelerating', 'isReversing', 'steering', 'controllerConnected', 'createdAt']) &&
             data.hostId is string && data.hostId.size() > 0 && data.hostId.size() < 50 &&
             data.isAccelerating is bool &&
             data.isReversing is bool &&
             data.steering is number &&
             data.controllerConnected is bool;
    }

    match /rooms/{roomId} {
      // Anyone authenticated can create a room if they set themselves as host
      allow create: if isAuthenticated() && 
                       isValidRoom(request.resource.data) &&
                       request.resource.data.hostId == request.auth.uid &&
                       roomId.matches('^[0-9]{4}$');
                       
      // Anyone authenticated can read a room (needed for the controller to join)
      allow read: if isAuthenticated();
      
      // Update rules:
      // 1. Host can update anything
      // 2. Controller can update isAccelerating and controllerConnected, but MUST NOT change hostId or createdAt
      allow update: if isAuthenticated() && 
                       isValidRoom(request.resource.data) &&
                       (
                         isOwner() || 
                         (
                           request.resource.data.hostId == resource.data.hostId &&
                           request.resource.data.createdAt == resource.data.createdAt
                         )
                       );
                       
      allow delete: if isOwner();
    }
  }
}
